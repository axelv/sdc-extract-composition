            "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>Patient: {{%resource.item.where(linkId='patient-name').answer.value}}</p><p>Date of birth: {{%resource.item.where(linkId='patient-dob').answer.value}}</p></div>"
          }
